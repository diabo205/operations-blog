---
import { siteConfig } from '../config/site';
const { linkedin, github, twitter, mastodon } = siteConfig.social;
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} {siteConfig.name}. All rights reserved.
	<div class="social-links">
		{linkedin && (
			<a href={linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
				<span class="sr-only">LinkedIn</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
					<path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
			</a>
		)}
		{github && (
			<a href={github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
					<path fill="currentColor" d="M12 0C5.374 0 0 5.373 0 12 0 17.302 3.438 21.8 8.207 23.387c.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
				</svg>
			</a>
		)}
		{twitter && (
			<a href={twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter">
				<span class="sr-only">Twitter</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
					<path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
				</svg>
			</a>
		)}
		{mastodon && (
			<a href={mastodon} target="_blank" rel="noopener noreferrer" aria-label="Mastodon">
				<span class="sr-only">Mastodon</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
					<path fill="currentColor" d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"/>
				</svg>
			</a>
		)}
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 3em 1em;
		color: var(--riso-teal);
		text-align: center;
		font-family: var(--font-technical);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		border-top: 1px solid var(--riso-teal);
		max-width: 56rem;
		margin: 0 auto;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: var(--riso-teal);
	}
	.social-links a:hover {
		color: var(--riso-vermilion);
	}
</style>
