---
/* Crisp SVG corner crosshair - replaces unicode registration marks
   which render inconsistently across fonts. Position via the class prop. */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---
<svg
  class={className}
  width="14"
  height="14"
  viewBox="0 0 14 14"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="0.75" />
  <line x1="0" y1="7" x2="14" y2="7" stroke="currentColor" stroke-width="0.75" />
  <line x1="7" y1="0" x2="7" y2="14" stroke="currentColor" stroke-width="0.75" />
  <circle cx="7" cy="7" r="1" fill="currentColor" />
</svg>
