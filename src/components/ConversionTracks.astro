---
const email = "obaid@glyphicx.com"
const phone = "+92 319 2001014"
---
<section class="conversion-section">
  <h2 class="section-heading">Contact</h2>
  <div class="contact-list">
    <div class="contact-item">
      <p class="contact-label">Email</p>
      <a href={`mailto:${email}`} class="contact-value">{email}</a>
    </div>
    <div class="contact-item">
      <p class="contact-label">Phone</p>
      <a href={`tel:${phone.replace(/\s/g, '')}`} class="contact-value">{phone}</a>
    </div>
  </div>
</section>

<style>
  .conversion-section {
    margin-top: 0;
    margin-bottom: 3rem;
  }
  .contact-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  .contact-item {
    border: 2px solid var(--riso-teal);
    background-color: var(--riso-paper);
    padding: 2rem;
  }
  .contact-label {
    font-family: var(--font-technical);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--riso-teal);
    opacity: 0.7;
    margin: 0 0 1rem;
  }
  .contact-value {
    font-family: var(--font-body);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--riso-teal);
    text-decoration: underline;
    text-decoration-color: var(--riso-vermilion);
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
    display: block;
    transition: color 0.15s ease;
  }
  .contact-value:hover {
    color: var(--color-riso-vermilion);
  }
  @media (max-width: 640px) {
    .contact-list {
      grid-template-columns: 1fr;
    }
    .contact-item {
      padding: 1.25rem;
    }
  }
</style>
