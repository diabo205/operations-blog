---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const title = `404 - Routing error · ${siteConfig.name}`;
---
<BaseLayout title={title} frameLabel="FILE 404 · ROUTING ERROR">
  <p style="font-family: var(--font-technical); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-riso-teal); opacity: 0.7; margin-bottom: 1rem;">
    Error 404 - Path not found in static graph
  </p>
  <h1>This route does not resolve.</h1>
  <p style="font-size: 1.1rem; margin-bottom: 2rem;">
    The URL you requested is not part of the published site map. This is
    usually a stale bookmark or a misrouted canonical. Use the navigation
    above, or return to the home page.
  </p>
  <a
    href="/"
    style="display:inline-block; text-decoration: none; font-family: var(--font-clinical); font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; padding: 0.875rem 1.5rem; font-size: 0.95rem; background-color: var(--color-riso-vermilion); color: var(--color-riso-paper); border: 2px solid var(--color-riso-vermilion);"
  >
    Return to index
  </a>
</BaseLayout>
