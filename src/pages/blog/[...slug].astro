---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MarkdownPostLayout from "../../layouts/MarkdownPostLayout.astro";
import { siteConfig } from "../../config/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<"blog"> };

const { post } = Astro.props;
const { Content } = await render(post);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { "@type": "Person", name: siteConfig.name, url: siteConfig.canonicalBaseUrl },
  publisher: { "@type": "Person", name: siteConfig.name, url: siteConfig.canonicalBaseUrl },
  mainEntityOfPage: `${siteConfig.canonicalBaseUrl}/blog/${post.id}/`,
};

const title = `${post.data.title} - ${siteConfig.name}`;
---
<BaseLayout
  title={title}
  description={post.data.description}
  frameLabel={`BLOG · ${post.data.title.toUpperCase().slice(0, 20)}`}
  jsonLd={articleSchema}
>
  <MarkdownPostLayout
    title={post.data.title}
    date={post.data.pubDate}
    updatedDate={post.data.updatedDate}
    heroImage={post.data.heroImage}
  >
    <Content />
  </MarkdownPostLayout>
</BaseLayout>
