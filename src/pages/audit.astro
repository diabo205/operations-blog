---
// Standalone Page — No external layout imports required
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hermes Council Audit Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased min-h-screen">

  <main class="max-w-4xl mx-auto p-6 my-8">
    <header class="border-b border-slate-200 pb-4 mb-8">
      <h1 class="text-3xl font-bold text-slate-900">👑 Hermes Council</h1>
      <p class="text-slate-500 mt-1">Autonomous 360° Website Architecture, Security, & Accessibility Auditing</p>
    </header>

    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm mb-8">
      <label for="url-input" class="block text-sm font-semibold text-slate-700 mb-2">Target Website URL</label>
      <div class="flex gap-3">
        <input 
          type="url" 
          id="url-input" 
          placeholder="https://example.com" 
          class="flex-1 px-4 py-3 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white"
        />
        <button 
          id="run-btn" 
          class="bg-indigo-600 hover:bg-indigo-700 text-white font-medium px-6 py-3 rounded-lg transition shadow-sm active:scale-95"
        >
          Run Council Audit
        </button>
      </div>
    </div>

    <div id="status-container" class="hidden bg-white border border-slate-200 rounded-xl p-6 mb-8 shadow-sm">
      <h3 class="font-semibold text-slate-900 mb-4 flex items-center gap-2">
        <span class="animate-pulse h-2 w-2 rounded-full bg-indigo-600"></span>
        Orchestrating Agents...
      </h3>
      <div class="space-y-3">
        <div id="step-crawl" class="flex items-center gap-3 text-slate-400">
          <div class="w-5 text-center font-bold">1</div>
          <p>Phase 1: Deep Crawl & Infrastructure Mapping</p>
        </div>
        <div id="step-security" class="flex items-center gap-3 text-slate-400">
          <div class="w-5 text-center font-bold">2</div>
          <p>Phase 2: Cryptographic & Security Header Inspection</p>
        </div>
        <div id="step-a11y" class="flex items-center gap-3 text-slate-400">
          <div class="w-5 text-center font-bold">3</div>
          <p>Phase 3: DOM-Level Accessibility Assessment</p>
        </div>
      </div>
    </div>

    <div id="results-container" class="hidden bg-white border border-slate-200 rounded-xl p-6 shadow-sm max-w-none">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Audit Findings</h2>
      <pre id="audit-markdown" class="whitespace-pre-wrap font-mono text-sm bg-slate-900 text-slate-100 p-6 rounded-lg overflow-x-auto max-h-[600px]"></pre>
    </div>
  </main>

  <script>
    const runBtn = document.getElementById('run-btn') as HTMLButtonElement;
    const urlInput = document.getElementById('url-input') as HTMLInputElement;
    const statusContainer = document.getElementById('status-container');
    const resultsContainer = document.getElementById('results-container');
    const markdownDisplay = document.getElementById('audit-markdown');

    const stepCrawl = document.getElementById('step-crawl');
    const stepSecurity = document.getElementById('step-security');
    const stepA11y = document.getElementById('step-a11y');

    runBtn?.addEventListener('click', async () => {
      const url = urlInput?.value.trim();
      if (!url) return alert('Please enter a valid target URL.');

      console.log('Initiating client-side fetch for target:', url);

      // Reset and display UI state
      statusContainer?.classList.remove('hidden');
      resultsContainer?.classList.add('hidden');
      
      if (stepCrawl && stepSecurity && stepA11y) {
        stepCrawl.className = "flex items-center gap-3 text-indigo-600 font-medium";
        stepSecurity.className = "flex items-center gap-3 text-slate-400";
        stepA11y.className = "flex items-center gap-3 text-slate-400";
      }

      try {
        const response = await fetch('http://localhost:3000/api/audit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url })
        });

        console.log('HTTP Handshake established. Response status:', response.status);

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(errorData.details || errorData.error || `Proxy backend returned status: ${response.status}`);
        }

        if (stepSecurity) stepSecurity.className = "flex items-center gap-3 text-indigo-600 font-medium";
        
        const data = await response.json();
        console.log('Payload data unpacked successfully:', data);
        
        if (stepA11y) stepA11y.className = "flex items-center gap-3 text-indigo-600 font-medium";

        if (resultsContainer && markdownDisplay) {
          statusContainer?.classList.add('hidden');
          resultsContainer.classList.remove('hidden');
          markdownDisplay.textContent = data.report || "No data returned.";
        }
      } catch (err: any) {
        console.error('Fatal connection breakdown:', err);
        alert(`Audit Execution Failed:\n${err.message}`);
        statusContainer?.classList.add('hidden');
      }
    });
  </script>
</body>
</html>