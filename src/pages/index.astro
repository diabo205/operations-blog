---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-w: 720px;
				margin: 0 auto;
				padding: 3em 1em;
			}
			section {
				margin-bottom: 3rem;
			}
			h1 {
				font-size: 2.5rem;
				margin-bottom: 0.5rem;
			}
			.subtitle {
				color: #666;
				font-size: 1.25rem;
				margin-bottom: 2rem;
			}
			.track-record-title {
				text-transform: uppercase;
				font-size: 0.85rem;
				letter-spacing: 0.05em;
				color: #666;
				border-bottom: 1px solid #eee;
				padding-bottom: 0.5rem;
				margin-bottom: 1.5rem;
			}
			.job-entry {
				margin-bottom: 1.5rem;
			}
			.job-entry h3 {
				margin-bottom: 0.25rem;
			}
			.job-meta {
				font-size: 0.9rem;
				color: #666;
				margin-bottom: 0.5rem;
			}
			.cta-buttons {
				display: flex;
				gap: 1.5rem;
				align-items: center;
				margin-top: 1rem;
			}
			.btn-primary {
				background: #111;
				color: #fff;
				padding: 0.5rem 1rem;
				text-decoration: none;
				border-radius: 4px;
				font-size: 0.9rem;
			}
			.btn-primary:hover {
				background: #333;
			}
			.btn-secondary {
				color: #666;
				text-decoration: none;
				font-size: 0.9rem;
			}
			.btn-secondary:hover {
				color: #111;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<header>
				<h1>Obaid Ur Rahman</h1>
				<p class="subtitle">Growth Operations & Strategy</p>
			</header>

			<!-- What I Do -->
			<section>
				<p>
					I build and optimize the digital sales infrastructure for technical business platforms. As the Operations and Creative Lead at GlyphicX and a growth strategist for enterprise ecosystems, I translate complex software capabilities into clear, high-signal market positioning.
				</p>
				<p>
					My work focuses purely on execution and data integrity—eliminating vague marketing narratives in favor of measurable pipeline performance.
				</p>
			</section>

			<!-- Proven Engagements -->
			<section>
				<h2 class="track-record-title">Track Record</h2>
				
				<div class="job-entry">
					<h3>Eaxeesoft (Odoo Consultancy)</h3>
					<div class="job-meta">Growth Operations & Funnel Strategist</div>
					<p>Architecting the digital sales infrastructure and growth funnels to scale regional Odoo implementations.</p>
				</div>

				<div class="job-entry">
					<h3>Eaxee (Enterprise Architecture Management)</h3>
					<div class="job-meta">Creative & Marketing Strategy via GlyphicX</div>
					<p>Directing the full-stack creative-tech pipeline to communicate high-level EAM value propositions. The platform is deployed at enterprise scale, including Red Sea Global.</p>
				</div>

				<div class="job-entry">
					<h3>Operational Excellence</h3>
					<div class="job-meta">Recognition</div>
					<p>Awarded by Mindstorm for distinct operational execution and strategic management.</p>
				</div>
			</section>

			<!-- Clear Call to Action -->
			<section style="border-top: 1px solid #eee; pt: 2rem;">
				<h3>Connect</h3>
				<p style="color: #666; font-size: 0.9rem;">For consulting, operational auditing, or strategic engagements.</p>
				<div class="cta-buttons">
					<a href="mailto:your.email@domain.com" class="btn-primary">
						Email Directly
					</a>
					<a href="https://linkedin.com/in/your-profile" target="_blank" rel="noopener noreferrer" class="btn-secondary">
						LinkedIn →
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>