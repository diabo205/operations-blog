---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Operations and Creative Lead.</h1>
<p>
  Architecting digital sales infrastructure for enterprise software and B2B SaaS. 
  I bridge the gap between complex technical value and market clarity.
</p>
<p>
  At <strong>GlyphicX</strong>, I lead a team of 8 in an AI-assisted creative pipeline. 
  As the fractional Head of Growth at <strong>Eaxeesoft</strong>, I am building 
  sales infrastructure for the EMEA Odoo market from scratch. 
  From deploying Enterprise Architecture Management platforms at Red Sea Global to 
  streamlining RevOps, I leverage my background in motion design to simplify 
  the complex.
</p>
		</main>
		<Footer />
	</body>
</html>
