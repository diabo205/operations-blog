---
import BaseLayout from "../layouts/BaseLayout.astro";
import RisoFrame from "../components/RisoFrame.astro";
import Hero from "../components/Hero.astro";
import TrackRecord from "../components/TrackRecord.astro";
import ConversionTracks from "../components/ConversionTracks.astro";
import { siteConfig } from "../config/site";

const title = `${siteConfig.name} - ${siteConfig.tagline}`.trim();
const description = [siteConfig.tagline, siteConfig.subTagline].filter(Boolean).join(". ");
---
<BaseLayout title={title} description={description}>
  <Hero />
  <RisoFrame label="FILE 003 · TRACK RECORD">
    <TrackRecord />
    <ConversionTracks />
  </RisoFrame>
</BaseLayout>
