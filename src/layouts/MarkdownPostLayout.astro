---
import { Image } from 'astro:assets';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
  title: string;
  date?: Date;
  updatedDate?: Date;
  heroImage?: string;
}

const { title, date, updatedDate, heroImage } = Astro.props;
---
<article class="prose max-w-none">
  {heroImage && (
    <div class="hero-image">
      <Image width={1020} height={510} src={heroImage} alt="" />
    </div>
  )}
  <div class="title">
    <div class="date">
      {date && <FormattedDate date={date} />}
      {updatedDate && (
        <div class="last-updated-on">
          Last updated on <FormattedDate date={updatedDate} />
        </div>
      )}
    </div>
    <h1>{title}</h1>
    <hr />
  </div>
  <slot />
</article>

<style>
  .hero-image {
    width: 100%;
    margin-bottom: 1.5rem;
  }
  .hero-image img {
    display: block;
    margin: 0 auto;
    border: 1px solid var(--color-riso-teal);
  }
  .prose {
    width: 100%;
    max-width: 100%;
    margin: auto;
    padding: 0;
    color: var(--color-riso-ink);
  }
  .title {
    margin-bottom: 1em;
    padding: 1em 0;
    text-align: center;
    line-height: 1;
  }
  .title h1 {
    margin: 0 0 0.5em 0;
  }
  .date {
    margin-bottom: 0.5em;
    color: var(--color-riso-teal);
    font-family: var(--font-technical);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .last-updated-on {
    font-style: italic;
  }
  hr {
    border: none;
    border-top: 1px solid var(--color-riso-teal);
    margin: 1.5rem 0;
  }
</style>
